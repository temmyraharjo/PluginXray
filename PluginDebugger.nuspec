<?xml version="1.0"?>
<package>
  <metadata>
    <id>PluginDebugger</id>
    <version>$version$</version>
    <title>PluginXray</title>
    <authors>Temmy Raharjo</authors>
    <owners>Temmy Raharjo</owners>
    <projectUrl>$projectUrl$</projectUrl>
    <iconUrl>$iconUrl$</iconUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Execute Dataverse plugins under a synthesized execution context with debugger attachment, without registering the plugin step first.</description>
    <summary>Debug Dataverse plugins in XrmToolBox without registration.</summary>
